# Local dev: point to Express (Vite and API on different ports)
# VITE_API_URL=http://localhost:5000/api
#
# Production (single Render Web Service — Express serves client/dist):
# Leave unset so the built app uses same-origin /api.
#
# Optional: split Deploy (static site + API) — set at build time to your API URL, no trailing slash:
# VITE_API_URL=https://your-api.onrender.com/api
